{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "./build",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": "..",
    "paths": {
      "@/*": ["*"]
    }
  },
  "include": [
    "*.ts",
    "../data/**/*.ts",
    "../lib/types.ts"
  ],
  "exclude": [
    "node_modules",
    "build",
    "../node_modules",
    "../.next",
    "../lib/airtable.ts",
    "../lib/email.ts",
    "../lib/utils.ts"
  ]
}
