# Obsidian MCP Server Configuration
# Copy this file to .env and fill in your actual values

# Required: Your Obsidian Local REST API key
# Find this in Obsidian Settings > Community Plugins > Local REST API
OBSIDIAN_API_KEY=your_api_key_here

# Optional: Host where Obsidian is running (default: 127.0.0.1)
OBSIDIAN_HOST=127.0.0.1

# Optional: Port for Obsidian Local REST API (default: 27124)
OBSIDIAN_PORT=27124
