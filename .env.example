# Royal Fit Uniform - Environment Variables
# Copy this file to .env.local and fill in your values

# ===========================================
# SITE CONFIGURATION
# ===========================================
NEXT_PUBLIC_SITE_URL=https://royalfituniform.com
NEXT_PUBLIC_SITE_NAME=Royal Fit Uniform

# ===========================================
# ANALYTICS (Optional)
# ===========================================
# Google Analytics 4 Measurement ID
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ===========================================
# AIRTABLE CRM INTEGRATION
# ===========================================
# Airtable Personal Access Token (create at https://airtable.com/create/tokens)
AIRTABLE_API_KEY=patXXXXXXXXXXXXXXXX

# Airtable Base ID (found in API documentation or URL)
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Airtable Table Name (exact name from your base)
AIRTABLE_TABLE_NAME=Quote Requests
