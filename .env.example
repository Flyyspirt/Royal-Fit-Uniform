# Royal Fit Uniform - Environment Variables
# Copy this file to .env.local and fill in your values

# ===========================================
# AIRTABLE CONFIGURATION
# ===========================================
# Get your API key from: https://airtable.com/create/tokens
AIRTABLE_API_KEY=pat_xxxxxxxxxxxxxxxxxxxx

# Get your Base ID from the Airtable URL when viewing your base
# URL format: https://airtable.com/appXXXXXXXXXXXXXX/...
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Table names (create these in your Airtable base)
AIRTABLE_LEADS_TABLE=Leads
AIRTABLE_PRODUCTS_TABLE=Products
AIRTABLE_ORDERS_TABLE=Orders
AIRTABLE_ANALYTICS_TABLE=Analytics

# ===========================================
# EMAIL CONFIGURATION (SendGrid)
# ===========================================
# Get your API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=royalfituniform@gmail.com
SENDGRID_FROM_NAME=Royal Fit Uniform

# ===========================================
# ANALYTICS
# ===========================================
# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ===========================================
# SITE CONFIGURATION
# ===========================================
NEXT_PUBLIC_SITE_URL=https://royalfituniform.com
NEXT_PUBLIC_SITE_NAME=Royal Fit Uniform

# ===========================================
# OPTIONAL: CRM INTEGRATION
# ===========================================
# HubSpot (if using)
# HUBSPOT_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ===========================================
# OPTIONAL: LIVE CHAT
# ===========================================
# Intercom App ID
# NEXT_PUBLIC_INTERCOM_APP_ID=xxxxxxxxx

# ===========================================
# OPTIONAL: CALENDAR BOOKING
# ===========================================
# Calendly embed URL
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/royalfituniform/consultation
